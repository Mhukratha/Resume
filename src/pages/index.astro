---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="container">
    <h1>YOSSAWIN<br>KASIPHONGPHAISAN</h1>
    <p class="sub">เลือก Resume ที่ต้องการ</p>

    <div class="buttons">
      <a href="/dev" class="btn btn-dev">
        <span class="btn-label">WEB DEVELOPER</span>
        <span class="btn-sub">System Integration & AI</span>
      </a>
      <a href="/staf" class="btn btn-staf">
        <span class="btn-label">EVENT STAFF</span>
        <span class="btn-sub">Operation & Support</span>
      </a>
    </div>
  </div>
</Layout>

<style>
  :global(body) {
    margin: 0;
    background: #111111;
    font-family: 'DM Sans', sans-serif;
  }

  .container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 24px;
    box-sizing: border-box;
  }

  h1 {
    font-family: 'Playfair Display', serif;
    font-size: 40px;
    font-weight: 700;
    color: #ffffff;
    text-align: center;
    line-height: 1.1;
    letter-spacing: -0.5px;
  }

  .sub {
    font-size: 12px;
    letter-spacing: 3px;
    color: #c9a84c;
    text-transform: uppercase;
    margin-bottom: 16px;
    text-align: center;
  }

  .buttons {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    justify-content: center;
    width: 100%;
    max-width: 440px;
  }

  .btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 200px;
    height: 120px;
    border: 1px solid #2a2a2a;
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
    background: #161616;
  }

  .btn-dev:hover {
    border-color: #c9a84c;
    background: #1a1a14;
  }

  .btn-staf:hover {
    border-color: rgba(255,255,255,0.3);
    background: #1a1a1a;
  }

  .btn-label {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 2px;
    color: #ffffff;
  }

  .btn-dev .btn-label { color: #c9a84c; }

  .btn-sub {
    font-size: 10px;
    color: rgba(255,255,255,0.3);
    letter-spacing: 1px;
    margin-top: 6px;
    text-align: center;
    padding: 0 12px;
  }

  /* ─────────────  RESPONSIVE  ───────────── */

  /* Tablet */
  @media (max-width: 768px) {
    h1 { font-size: 32px; }
  }

  /* Mobile: stack the two buttons and let them fill the width */
  @media (max-width: 480px) {
    h1 { font-size: 26px; }
    .sub { font-size: 11px; letter-spacing: 2px; }

    .buttons {
      flex-direction: column;
      align-items: stretch;
      max-width: 280px;
    }
    .btn {
      width: 100%;
      height: 100px;
    }
  }
</style>
---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Yossawin Kasiphongphaisan — Web Developer">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />

  <div class="dev-resume-body">
    <div class="page">

      <div class="header">
        <div class="header-left">
          <h1>YOSSAWIN<br>KASIPHONGPHAISAN</h1>
          <div class="role">Web Application Developer &amp; System Integration</div>
          <div class="location">Bangkok, Thailand</div>
        </div>
        <img src="IMG_3677.jpg" alt="Yossawin Kasisphongphaisan" class="profile-photo" />
      </div>

      <div class="body">
        <div class="sidebar">

          <div class="sidebar-section">
            <div class="sidebar-label">ติดต่อ</div>
            <div class="contact-item"><span class="contact-icon">☎</span><span>083-052-5476</span></div>
            <div class="contact-item"><span class="contact-icon">✉</span><span>mhukratha@gmail.com</span></div>
            <div class="contact-item"><span class="contact-icon">◈</span><span>GitHub</span></div>
            <div class="contact-item"><span class="contact-icon">◈</span><span>Portfolio</span></div>
          </div>

          <div class="sidebar-section">
            <div class="sidebar-label">Technical Skills</div>

            <div class="skill-group">
              <div class="skill-group-name">Languages</div>
              <div class="skill-tags">
                <span class="skill-tag white-accent">JavaScript</span>
                <span class="skill-tag white-accent">C#</span>
                <span class="skill-tag">HTML5</span>
                <span class="skill-tag">CSS3</span>
              </div>
            </div>

            <div class="skill-group">
              <div class="skill-group-name">Frontend</div>
              <div class="skill-tags">
                <span class="skill-tag white-accent">React</span>
                <span class="skill-tag">Astro</span>
                <span class="skill-tag">Tailwind CSS</span>
              </div>
            </div>

            <div class="skill-group">
              <div class="skill-group-name">Backend &amp; API</div>
              <div class="skill-tags">
                <span class="skill-tag">Node.js</span>
                <span class="skill-tag">REST API</span>
                <span class="skill-tag">System Integration</span>
              </div>
            </div>

            <div class="skill-group">
              <div class="skill-group-name">AI &amp; Emerging</div>
              <div class="skill-tags">
                <span class="skill-tag highlight">Generative AI</span>
                <span class="skill-tag highlight">Chatbot Integration</span>
                <span class="skill-tag highlight">Automation</span>
              </div>
            </div>

            <div class="skill-group">
              <div class="skill-group-name">Tools</div>
              <div class="skill-tags">
                <span class="skill-tag">Git</span>
                <span class="skill-tag">GitHub</span>
                <span class="skill-tag">VS Code</span>
                <span class="skill-tag">Figma</span>
              </div>
            </div>
          </div>

          <div class="sidebar-section">
            <div class="sidebar-label">Languages</div>
            <div class="lang-item">
              <span class="lang-name">Thai</span>
              <span class="lang-level">Native</span>
            </div>
            <div class="lang-item">
              <span class="lang-name">English</span>
              <span class="lang-level">Intermediate</span>
            </div>
          </div>

          <div class="sidebar-section">
            <div class="sidebar-label">Core Concepts</div>
            <div class="skill-tags">
              <span class="skill-tag">OOP</span>
              <span class="skill-tag">Agile / Scrum</span>
              <span class="skill-tag">Debugging</span>
              <span class="skill-tag">Unit Testing</span>
              <span class="skill-tag">Technical Docs</span>
              <span class="skill-tag">SDLC</span>
            </div>
          </div>

        </div>

        <div class="main">

          <div class="section">
            <div class="section-title">Profile Summary</div>
            <div class="white-rule"></div>
            <p class="summary-text">
              Junior developer with hands-on experience in front-end web development and a strong programming foundation in C# and OOP. Experienced in building and deploying real-world web applications, REST API integration, and Agile/Scrum workflows. Actively exploring Generative AI and automation solutions. Fast learner, analytical, and able to work independently while delivering clean, maintainable code.
            </p>
          </div>

          <div class="section">
            <div class="section-title">Experience &amp; Projects</div>
            <div class="white-rule"></div>

            <div class="job">
              <div class="job-title">Front-End Developer — Nattakorn Electric &amp; Construction</div>
              <div class="job-company">Freelance Project</div>
              <div class="job-link">nattakorn-electric-and-construction.pages.dev</div>
              <ul>
                <li class="w">Designed and developed a full responsive corporate web application using Astro and Tailwind CSS</li>
                <li class="w">Integrated deployment pipeline via Cloudflare Pages — validated performance and cross-browser compatibility post-launch</li>
                <li>Gathered client requirements, provided technical consultation, and delivered a solution meeting business needs</li>
                <li>Performed debugging, performance optimization, and maintained technical documentation</li>
              </ul>
            </div>

            <div class="job">
              <div class="job-title">Junior Programmer — I Must Survive (Game Project)</div>
              <div class="job-company">Bangkok University Capstone</div>
              <ul>
                <li class="w">Led development roadmap and coordinated tasks across the team using Agile principles</li>
                <li class="w">Developed player systems, enemy AI, and physics interactions in C# — system design and multi-module integration</li>
                <li>Performed unit testing and debugging of complex gameplay systems; documented issues and resolutions</li>
              </ul>
            </div>

            <div class="job">
              <div class="job-title">Junior Programmer — NeonRush (Game Project)</div>
              <div class="job-company">Bangkok University Project</div>
              <ul>
                <li class="w">Built and integrated health systems, hazard logic, and movement mechanics in C# with OOP architecture</li>
                <li>Performed systematic debugging and testing; maintained technical documentation of system behaviors</li>
              </ul>
            </div>

            <div class="job">
              <div class="job-title">3D Environment Artist — Aenalia Metaverse Application</div>
              <div class="job-company">Professional Project</div>
              <ul>
                <li>Collaborated with cross-functional team to validate deliverables against technical and visual specifications</li>
                <li>Designed and integrated 3D environments and animations in Unreal Engine</li>
              </ul>
            </div>
          </div>

          <div class="section">
            <div class="section-title">Education</div>
            <div class="white-rule"></div>
            <div class="job">
              <div class="job-title">Bachelor of Science in Games and Interactive Media</div>
              <div class="job-company">Bangkok University</div>
            </div>
          </div>

        </div>
      </div>

      <div class="footer">
        <div class="footer-left">Official Resume</div>
        <div class="footer-right">Yossawin Kasiphongphaisan · 083-052-5476</div>
      </div>

    </div>
  </div>
</Layout>

<style>
  /* ครอบสไตล์ให้อยู่ภายใน Component นี้ และเซ็ตค่าพื้นหลังเริ่มต้นตามสไตล์ดั้งเดิมของคุณ */
  .dev-resume-body {
    font-family: 'DM Sans', sans-serif;
    background: #0d0d0d;
    color: #e8e0cc;
    min-height: 100vh;
  }

  .page {
    max-width: 860px;
    margin: 0 auto;
    background: #111111;
    min-height: 100vh;
  }

  .header {
    background: #111111;
    padding: 48px 48px 32px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    border-bottom: 1px solid #2a2a2a;
    position: relative;
  }
  .header::after {
    content: '';
    position: absolute;
    bottom: -1px; left: 70px;
    width: 80px; height: 2px;
    background: #c9a84c;
  }
  .header-left h1 {
    font-family: 'Playfair Display', serif;
    font-size: 42px;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.1;
    letter-spacing: -0.5px;
  }
  .header-left .role {
    font-size: 13px;
    color: #c9a84c;
    margin-top: 6px;
    letter-spacing: 3px;
    font-weight: 300;
    text-transform: uppercase;
  }
  .header-left .location {
    font-size: 12px;
    color: rgba(255,255,255,0.35);
    margin-top: 8px;
    letter-spacing: 1px;
  }
  .profile-photo {
    width: 140px;
    height: 170px;
    object-fit: cover;
    object-position: center top;
    border: 2px solid #333;
    outline: 1px solid rgba(255,255,255,0.08);
    filter: grayscale(20%) contrast(1.2);
    flex-shrink: 0;
  }

  .body {
    display: grid;
    grid-template-columns: 220px 1fr;
    min-height: calc(100vh - 200px);
  }

  .sidebar {
    background: #161616;
    padding: 36px 28px;
    border-right: 1px solid #2a2a2a;
  }
  .sidebar-section { margin-bottom: 32px; }
  .sidebar-label {
    font-size: 9px;
    letter-spacing: 3px;
    color: #c9a84c;
    text-transform: uppercase;
    font-weight: 500;
    margin-bottom: 14px;
    padding-bottom: 6px;
    border-bottom: 1px solid #2a2a2a;
  }
  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 10px;
    font-size: 12px;
    color: rgba(255,255,255,0.7);
    line-height: 1.4;
  }
  .contact-icon { color: #c9a84c; font-size: 13px; margin-top: 1px; flex-shrink: 0; }

  /* Skill pills */
  .skill-group { margin-bottom: 14px; }
  .skill-group-name {
    font-size: 9px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.25);
    margin-bottom: 6px;
  }
  .skill-tags { display: flex; flex-wrap: wrap; gap: 4px; }
  .skill-tag {
    font-size: 10px;
    padding: 3px 8px;
    border: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.3px;
  }
  .skill-tag.highlight {
    border-color: rgba(201,168,76,0.4);
    color: #c9a84c;
  }
  .skill-tag.white-accent {
    border-color: rgba(255,255,255,0.25);
    color: rgba(255,255,255,0.75);
  }

  .lang-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }
  .lang-name { font-size: 13px; color: #ffffff; font-weight: 500; opacity: 0.9; }
  .lang-level {
    font-size: 10px;
    padding: 2px 8px;
    border: 1px solid rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.4);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* MAIN */
  .main { padding: 36px 40px; }
  .section { margin-bottom: 34px; }
  .section-title {
    font-size: 9px;
    letter-spacing: 4px;
    color: #c9a84c;
    text-transform: uppercase;
    font-weight: 500;
    margin-bottom: 6px;
    padding-bottom: 8px;
    border-bottom: 1px solid #2a2a2a;
  }
  .white-rule {
    height: 1px;
    background: linear-gradient(to right, rgba(255,255,255,0.12), transparent);
    margin-bottom: 18px;
  }
  .summary-text {
    font-size: 12.5px;
    color: rgba(255,255,255,0.55);
    line-height: 1.8;
    border-left: 2px solid rgba(255,255,255,0.08);
    padding-left: 14px;
  }
  .job {
    margin-bottom: 24px;
    padding-left: 14px;
    border-left: 2px solid #2a2a2a;
    position: relative;
  }
  .job::before {
    content: '';
    position: absolute;
    left: -4px; top: 6px;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #c9a84c;
  }
  .job-title { font-size: 14px; font-weight: 500; color: #ffffff; line-height: 1.3; }
  .job-company { font-size: 11px; color: #c9a84c; margin-top: 2px; letter-spacing: 0.5px; }
  .job-link { font-size: 10px; color: rgba(255,255,255,0.25); font-style: italic; margin-top: 1px; word-break: break-all; }
  .job ul { margin-top: 10px; padding-left: 0; list-style: none; }
  .job ul li {
    font-size: 12px;
    color: rgba(255,255,255,0.48);
    line-height: 1.7;
    padding-left: 14px;
    position: relative;
    margin-bottom: 4px;
  }
  .job ul li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: #c9a84c;
    font-size: 10px;
    top: 3px;
  }
  /* white-accented list items */
  .job ul li.w {
    color: rgba(255,255,255,0.72);
  }
  .job ul li.w::before { color: rgba(255,255,255,0.3); }

  .footer {
    background: #0d0d0d;
    padding: 16px 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid #2a2a2a;
    flex-wrap: wrap;
    gap: 6px;
  }
  .footer-left { font-size: 10px; letter-spacing: 2px; color: rgba(255,255,255,0.2); text-transform: uppercase; }
  .footer-right { font-size: 10px; color: rgba(255,255,255,0.3); }

  /* ─────────────  RESPONSIVE  ───────────── */

  /* Tablet */
  @media (max-width: 768px) {
    .header {
      padding: 36px 28px 24px;
    }
    .header::after { left: 28px; }
    .header-left h1 { font-size: 32px; }
    .profile-photo { width: 100px; height: 122px; }

    .body {
      grid-template-columns: 1fr;
    }
    .sidebar {
      border-right: none;
      border-bottom: 1px solid #2a2a2a;
      padding: 28px 28px;
    }
    .main { padding: 28px; }

    .footer { padding: 14px 28px; }
  }

  /* Mobile */
  @media (max-width: 480px) {
    .header {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
      padding: 28px 20px 20px;
    }
    .header::after { left: 20px; width: 60px; }
    .header-left h1 { font-size: 26px; }
    .header-left .role { font-size: 11px; letter-spacing: 2px; }
    .profile-photo { width: 88px; height: 108px; }

    .sidebar { padding: 22px 20px; }
    .main { padding: 22px 20px; }

    .job-title { font-size: 13px; }
    .summary-text { font-size: 12px; padding-left: 10px; }

    .footer {
      flex-direction: column;
      align-items: flex-start;
      padding: 14px 20px;
    }
  }
</style>